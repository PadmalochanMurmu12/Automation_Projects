<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!-- Added parallel="tests" to trigger cross-browser execution simultaneously -->
<suite name="Swaglab_Automation_TestSuite">
  
  <listeners>
    <!-- Updated path to reflect the new com.qa.utils package -->
    <listener class-name="com.qa.utils.Suite_Listener" />
  </listeners>

  <test name="ChromeTest">
    <parameter name="browser" value="chrome"></parameter>
    <classes>
      <class name="com.qa.tests.SingleProduct"/>
    </classes>
  </test>

  <test name="FirefoxTest">
    <parameter name="browser" value="firefox"></parameter> <!-- Lowercased for consistency -->
    <classes>
      <class name="com.qa.tests.SingleProduct"/>
    </classes>
  </test>

  <test name="EdgeTest">
    <parameter name="browser" value="edge"></parameter> <!-- Lowercased for consistency -->
    <classes>
      <class name="com.qa.tests.SingleProduct"/>
    </classes>
  </test>

</suite>